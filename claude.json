{
  "name": "学员管理平台",
  "description": "基于 Vue 3 + Node.js + MySQL 的学员日常管理平台",
  "version": "1.0.0",
  "author": "Linxuan",
  "license": "MIT",
  "scripts": {
    "dev": "npm run dev:backend && npm run dev:frontend",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "start": "npm run start:backend && npm run start:frontend",
    "start:backend": "cd backend && npm start",
    "start:frontend": "cd frontend && npm start",
    "docker:up": "cd docker && docker-compose up -d",
    "docker:down": "cd docker && docker-compose down",
    "docker:logs": "cd docker && docker-compose logs -f",
    "test": "echo \"No tests configured yet\""
  },
  "dependencies": {
    "backend": "cd backend && npm install",
    "frontend": "cd frontend && npm install"
  },
  "env": {
    "NODE_ENV": "development",
    "DB_HOST": "localhost",
    "DB_PORT": "3306",
    "DB_NAME": "ripple_learning_platform",
    "DB_USER": "root",
    "DB_PASSWORD": "password",
    "JWT_SECRET": "your_jwt_secret_key_here",
    "FRONTEND_URL": "http://localhost:3000"
  },
  "notes": [
    "使用 npm run dev 启动开发环境",
    "使用 npm run docker:up 启动Docker部署",
    "默认管理员账号：admin/password",
    "请及时修改默认密码和JWT密钥"
  ]
}